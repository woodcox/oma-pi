echo
echo "Welcome to PimaTerm ūüöÄ, let's get you set up."
echo

# Git identity
if ! git config --global user.name &>/dev/null || ! git config --global user.email &>/dev/null; then
  if gum confirm "Identify for Git?"; then
    source ~/.config/shell/functions
    git-id
  fi
fi

# GitHub CLI
if ! gh auth status &>/dev/null; then
  echo
  if gum confirm "Authenticate with GitHub?"; then
    gh auth login
  fi
fi

# Tailscale
if command -v tailscale &>/dev/null && ! tailscale status &>/dev/null; then
  echo
  if gum confirm "Connect to Tailscale?"; then
    sudo tailscaled &>/dev/null &
    sudo tailscale up --ssh --accept-routes
  fi
fi

echo
echo "‚úď Setup complete!"
touch "$MARKER"
exec /bin/bash -l "$@"
